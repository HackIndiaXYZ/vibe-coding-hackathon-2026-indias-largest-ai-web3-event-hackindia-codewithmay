# ─── LLM Provider ──────────────────────────────────────────────────────────────
# Choose ONE: ollama | anthropic | openai
LLM_PROVIDER=anthropic

# ─── Ollama (local, default) ───────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:120b-cloud

# ─── Anthropic Claude ──────────────────────────────────────────────────────────
# Get your key: https://console.anthropic.com/settings/keys
# Recommended models: claude-opus-4-20250514 | claude-sonnet-4-20250514 | claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=sk-Vg74UY6JhFyeV8M0bN7qQKJAql0PokPqZSOnL8xjbjq0M1fm
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── OpenAI GPT-4 ──────────────────────────────────────────────────────────────
# Get your key: https://platform.openai.com/api-keys
# Recommended models: gpt-4o | gpt-4-turbo | gpt-4o-mini
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ─── Google Cloud Text-to-Speech ───────────────────────────────────────────────
# Get your key: https://console.cloud.google.com/apis/credentials
# Enable the "Cloud Text-to-Speech API" in your project first.
GOOGLE_TTS_API_KEY=your_google_tts_api_key_here

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ─── SerpApi (Google Images) ───────────────────────────────────────────────────
# Get your key: https://serpapi.com/manage-api-key
SERPAPI_KEY=your_serpapi_key_here

# ─── Avatar Persona Config (optional) ──────────────────────────────────────────
# Path to a JSON config file that overrides the default persona settings.
# Fields: name, role, traits, dialogueBehavior, systemPrompt
#
# Example file: avatar.config.json
# {
#   "name":            "Dr. Maya",
#   "role":            "Cardiology Consultant",
#   "traits":          "direct, evidence-based, empathetic",
#   "dialogueBehavior": "concise",
#   "systemPrompt":    "You are Dr. Maya, a Cardiology Consultant with 20 years of experience..."
# }
#
# AVATAR_CONFIG_PATH=./avatar.config.json
